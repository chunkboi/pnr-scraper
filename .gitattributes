# Normalize line endings for all text files to LF in the repository.
# Windows checkouts get CRLF via core.autocrlf; the repo always stores LF.

* text=auto eol=lf

# Rust source
*.rs      text eol=lf
*.toml    text eol=lf
*.lock    text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf

# PowerShell — keep CRLF on Windows checkout so cmd.exe / PS can run them
*.ps1     text eol=crlf
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Binary files — never mangle
*.exe     binary
*.dll     binary
*.lib     binary
*.pdb     binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.traineddata binary
